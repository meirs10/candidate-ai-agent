# Copy this file to .streamlit/secrets.toml (gitignored) for local runs, or paste
# its contents into the Secrets box of Streamlit Community Cloud / Hugging Face
# Spaces for the hosted deployment. NEVER commit real keys.

# --- Required for the production (Option A) serve path ---
ANTHROPIC_API_KEY = "sk-ant-..."     # https://console.anthropic.com
VOYAGE_API_KEY    = "pa-..."          # https://dashboard.voyageai.com

# --- Access control ---
APP_PASSWORD = "choose-a-shared-code" # the code you hand to recruiters
APP_MODE     = "production"           # hides the Candidate Setup page

# --- Providers (these are already the defaults; shown for clarity) ---
LLM_PROVIDER    = "anthropic"
EMBED_PROVIDER  = "voyage"
RERANK_PROVIDER = "voyage"

# --- Optional overrides ---
# AGENT_MODEL  = "claude-haiku-4-5"   # bump to "claude-sonnet-4-6" for richer answers
# ROUTER_MODEL = "claude-haiku-4-5"
