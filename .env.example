# Environment-variable form of the settings (env vars take precedence over
# Streamlit secrets). Useful for the local build step and the eval harness.
# Copy to .env and `export` them, or set them in your shell / CI.

# Production serve path (Option A: all-API)
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
APP_PASSWORD=choose-a-shared-code
APP_MODE=production
LLM_PROVIDER=anthropic
EMBED_PROVIDER=voyage
RERANK_PROVIDER=voyage

# ── To build/update the profile locally, expose the setup page: ──
# APP_MODE=setup

# ── To run the original 100%-local stack (free eval, no API): ──
# LLM_PROVIDER=ollama
# EMBED_PROVIDER=nomic
# RERANK_PROVIDER=qwen3
